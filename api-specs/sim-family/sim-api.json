  "paths": {
    "/oauth2/token": {
      "post": {
        "summary": "Get Token",
        "operationId": "get-token",
        "tags": [
          "Get Token"
        ],
        "description": "**Usage**: This API is used to obtain an OAuth2 token for authentication. The response will include an `access_token` which is stored in the collection variables for use in subsequent requests.\n\n**Method**: POST  \n**URL**: `https://eseye-idp-{{env}}.auth.eu-west-1.amazoncognito.com/oauth2/token`  \n**Headers**: Authorization (Basic {{base64}})  \n**Body**: URL encoded parameters for `grant_type` and `scope`  \n**Event**: Sets the token in collection variables upon receiving the response.\n\n**Parameters**:\n\n- **Authorization**: This header contains the base64 encoded client credentials. The value is set to `Basic {{base64}}`, where `{{base64}}` is an environment variable containing the base64 encoded client ID and client secret.\n    \n- **grant_type**: This parameter is set to `client_credentials`, indicating that the client is using its own credentials to obtain an access token.\n    \n- **scope**: This parameter is set to `api/api`, specifying the scope of the access token.",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "grant_type": "client_credentials",
                "scope": "api/api"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "servers": [
          {
            "url": "https://eseye-idp-{env}.auth.eu-west-1.amazoncognito.com",
            "variables": {
              "env": {
                "default": "prod",
                "description": "Postman variable: env"
              }
            }
          }
        ],
        "security": []
      }
    },
