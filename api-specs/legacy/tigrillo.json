                          "start": {
                            "type": "string"
                          },
                          "stop": {
                            "type": "string"
                          },
                          "description": {
                            "type": "string"
                          },
                          "quantity": {
                            "type": "integer"
                          },
                          "price": {
                            "type": "string"
                          },
                          "mcc": {
                            "type": "string"
                          },
                          "mnc": {
                            "type": "string"
                          },
