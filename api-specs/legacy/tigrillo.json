                  "password": {
                    "type": "string"
                  },
                  "portfolioID": {
                    "type": "string"
                  }
                },
                "required": [
                  "username",
                  "password",
                  "portfolioID"
                ]
              },
              "example": {
                "username": "Example@Username.com",
                "password": "examplepassword",
                "portfolioID": "CustomerPortfolioID"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "object",
                      "properties": {
                        "errorCode": {
                          "type": "string"
                        },
                        "errorMessage": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string"
                        }
                      }
                    },
                    "cookie": {
                      "type": "string"
                    },
                    "permissions": {
                      "type": "string"
                    },
                    "canActivate": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": {
                    "errorCode": "",
                    "errorMessage": "",
                    "status": "OK"
                  },
                  "cookie": "01eq42isi4e2ksr2p6dq7jfut2",
                  "permissions": "UEFLA",
                  "canActivate": "yes"
                }
              }
            }
          }
        }
