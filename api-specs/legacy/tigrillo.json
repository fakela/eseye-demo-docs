    "/Japi/Tigrillo/activateSIMs": {
      "post": {
        "summary": "activateSIMs",
        "operationId": "post-japi-tigrillo-activatesims",
        "tags": [
          "Tigrillo API"
        ],
        "description": "Activates single or multiple SIMs. Eseye SIMs are available, ready to become active. Before you make one or more SIMs active, you must have a signed Service Contract form agreeing to the associated costs. You must ass...",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sims": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "ICCID": {
                          "type": "string"
                        },
                        "friendlyName": {},
                        "IMEI": {}
                      }
                    }
                  },
                  "tariffID": {},
                  "group": {},
                  "device": {}
                },
                "required": [
                  "sims"
                ]
              },
              "example": {
                "sims": [
                  {
                    "ICCID": "8944538523012555999",
                    "friendlyName": null,
                    "IMEI": null
                  },
                  {
                    "ICCID": "8944538523013333111",
                    "friendlyName": null,
                    "IMEI": null
                  }
                ],
                "tariffID": null,
                "group": null,
                "device": null
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string"
                        },
                        "errorCode": {
                          "type": "string"
                        },
                        "errorMessage": {
                          "type": "string"
                        }
                      }
                    },
                    "simStatuses": {
                      "type": "object",
                      "properties": {
                        "8944538523013333111": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "status": {
                    "status": "OK",
                    "errorCode": "",
                    "errorMessage": ""
                  },
                  "simStatuses": {
                    "8944538523013333111": "SIM is pending activation"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/Japi/Tigrillo/getCookieName": {
      "post": {
        "summary": "getCookieName",
        "operationId": "post-japi-tigrillo-getcookiename",
        "tags": [
          "Tigrillo API"
        ],
        "description": "Returns the name of the HTTP cookie needed for sessions to continue without the need to log in each time. A cookie is valid for 4 hours after it is generated.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                },
                "example": "PHPSESSID"
              }
            }
          }
        }
      }
    },
    "/Japi/Tigrillo/getSIMBilling": {
